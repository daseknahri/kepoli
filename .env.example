SITE_URL=https://kepoli.com
SITE_EMAIL=contact@kepoli.com
WRITER_EMAIL=isalunemerovik@gmail.com
WP_LOCALE=ro_RO
WP_ADMIN_LOCALE=en_US
KEPOLI_AUTOSEED_ENABLE=1
KEPOLI_FORCE_RESEED=0
CANONICAL_REDIRECT_HOSTS=www.kepoli.com,api.kepoli.com,recipe.kepoli.com

WORDPRESS_DB_NAME=kepoli
WORDPRESS_DB_USER=kepoli
WORDPRESS_DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change-me-admin
WP_ADMIN_EMAIL=contact@kepoli.com

# Optional: keep ads paused until Google Privacy & Messaging / your certified CMP is live.
ADSENSE_CLIENT_ID=ca-pub-8166411196603757
ADSENSE_PUB_ID=pub-8166411196603757
ADSENSE_ENABLE=0
ADSENSE_SLOT_HEADER=
ADSENSE_SLOT_AFTER_INTRO=
ADSENSE_SLOT_MID_CONTENT=
ADSENSE_SLOT_SIDEBAR=
ADSENSE_SLOT_BELOW_CONTENT=
EZOIC_ADSTXT_ACCOUNT_ID=
EZOIC_ADSTXT_REDIRECT_URL=

# Optional Google services.
GA_ENABLE=0
GA_MEASUREMENT_ID=
SEARCH_CONSOLE_VERIFICATION=

# Optional lightweight traffic counter. Use a hidden Histats counter and base64-encode the full code.
HISTATS_ENABLE=0
HISTATS_CODE_BASE64=
HISTATS_EXCLUDE_ADMINS=1

# Optional AI repair for author-tools extraction. Keep disabled unless an API key is configured.
AI_EXTRACTION_ENABLE=0
AI_EXTRACTION_PROVIDER=openrouter
AI_EXTRACTION_API_KEY=
AI_EXTRACTION_MODEL=inclusionai/ling-2.6-1t:free
AI_EXTRACTION_TIMEOUT_SECONDS=14
AI_EXTRACTION_MAX_CHARS=9000
AI_EXTRACTION_MAX_TOKENS=1400

# Optional deploy verification. Keep off for normal production pages.
KEPOLI_DEPLOY_FINGERPRINT=0
